#!/bin/bash

echo "[stop-server] saving world before shutdown"
/scripts/send-command "SaveWorld" 2>/dev/null || true
sleep 5

echo "[stop-server] sending DoExit via RCON"
/scripts/send-command "DoExit" 2>/dev/null || true

# Wait for server process to exit (up to 60s -- ARK is slow to shut down)
for i in $(seq 1 60); do
    if ! pgrep -f "ShooterGameServer" > /dev/null 2>&1; then
        echo "[stop-server] server stopped gracefully"
        exit 0
    fi
    sleep 1
done

echo "[stop-server] timeout waiting for graceful shutdown, force killing"
pkill -9 -f "ShooterGameServer" 2>/dev/null || true
exit 1
